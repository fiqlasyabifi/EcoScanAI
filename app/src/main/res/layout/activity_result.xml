<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_title_page"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hasil Analisis AI"
            android:fontFamily="@font/poppins"
            android:textColor="@color/green_primary_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/card_result_image"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_title_page">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/img_captured_result"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Hasil Pindaian Sampah"
                    tools:src="@android:drawable/ic_menu_gallery" />

            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/badge_confidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/green_light_badge"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_result_image">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="@color/green_text_badge"
                    android:contentDescription="Terverifikasi" />

                <TextView
                    android:id="@+id/tv_accuracy_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="98% TINGKAT KEYAKINAN"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/green_text_badge"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_waste_classification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Plastik"
            android:fontFamily="@font/poppins"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@+id/badge_confidence" />

        <TextView
            android:id="@+id/tv_waste_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="12dp"
            android:text="PET Tipe 1. Dapat didaur ulang secara luas dalam program pengelolaan sampah."
            android:fontFamily="@font/poppins"
            android:textAlignment="center"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@+id/tv_waste_classification" />

        <androidx.cardview.widget.CardView
            android:id="@+id/card_tips_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_waste_subtitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="@color/green_primary_dark"
                        android:contentDescription="Ikon Tips" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Tips Daur Ulang"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/green_primary_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="2dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/gray_text"
                        android:contentDescription="Poin 1" />
                    <TextView
                        android:id="@+id/tvTip1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Bilas hingga bersih sebelum dibuang untuk mencegah kontaminasi."
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/black"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="2dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/gray_text"
                        android:contentDescription="Poin 2" />
                    <TextView
                        android:id="@+id/tvTip2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Periksa warna tempat sampah lokal (biasanya Biru atau Kuning untuk plastik)."
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/black"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="2dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/gray_text"
                        android:contentDescription="Poin 3" />
                    <TextView
                        android:id="@+id/tvTip3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Lepas tutup botol jika diwajibkan oleh fasilitas setempat."
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/black"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_find_nearest_bin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="10dp"
            android:text="Cari Bank Sampah terdekat"
            android:fontFamily="@font/poppins"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="@color/green_primary"
            app:cornerRadius="27dp"
            app:icon="@android:drawable/ic_menu_mylocation"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_tips_container" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>